<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Equilibrio" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_600</item>
        <item name="colorPrimaryVariant">@color/teal_800</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_400</item>
        <item name="colorSecondaryVariant">@color/teal_600</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.Equilibrio.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal_600</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.Equilibrio.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/gray_200</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
    </style>

    <style name="Widget.Equilibrio.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/gray_200</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="TextAppearance.Equilibrio.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Equilibrio.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/gray_400</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
