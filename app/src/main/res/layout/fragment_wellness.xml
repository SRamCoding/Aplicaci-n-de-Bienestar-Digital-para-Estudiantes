<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Bienestar" android:textSize="22sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/gray_900"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Consejos y herramientas de relajación" android:textSize="13sp"
            android:textColor="@color/gray_400" android:layout_marginBottom="16dp"/>

        <!-- Tip destacado -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/teal_50">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="top">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⭐" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CONSEJO DESTACADO" android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/teal_800"
                        android:letterSpacing="0.06" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Practica la regla 20-20-20: cada 20 min, mira a 6 metros de distancia por 20 segundos. Reduce la fatiga visual."
                        android:textSize="13sp" android:textColor="@color/teal_900" android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ejercicios rápidos -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="EJERCICIOS RÁPIDOS" android:textSize="11sp"
            android:fontFamily="sans-serif-medium" android:textColor="@color/gray_400"
            android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>

        <!-- Respiración -->
        <androidx.cardview.widget.CardView android:id="@+id/cardBreathing"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="42dp" android:layout_height="42dp"
                    android:gravity="center" android:text="🧘" android:textSize="22sp"
                    android:background="@color/teal_50" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Respiración 4-7-8" android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="3 minutos · Reduce ansiedad" android:textSize="12sp" android:textColor="@color/gray_400"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▶" android:textSize="18sp" android:textColor="@color/teal_600"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pomodoro -->
        <androidx.cardview.widget.CardView android:id="@+id/cardPomodoro"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:clickable="true" android:focusable="true"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="42dp" android:layout_height="42dp"
                    android:gravity="center" android:text="🍅" android:textSize="22sp"
                    android:background="@color/red_50" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Técnica Pomodoro" android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="25 min trabajo + 5 min descanso" android:textSize="12sp" android:textColor="@color/gray_400"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▶" android:textSize="18sp" android:textColor="@color/red_400"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tips adicionales -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="HÁBITOS SALUDABLES" android:textSize="11sp"
            android:fontFamily="sans-serif-medium" android:textColor="@color/gray_400"
            android:letterSpacing="0.08" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/gray_100">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌙" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Higiene del sueño" android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Evita pantallas 1h antes de dormir" android:textSize="11sp" android:textColor="@color/gray_600"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/gray_100">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💧" android:textSize="22sp" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hidratación" android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="8 vasos de agua al día mejoran el rendimiento" android:textSize="11sp" android:textColor="@color/gray_600"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
