<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:padding="16dp">

    <TextView android:id="@+id/btnBack"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="← Bienestar" android:textSize="13sp" android:textColor="@color/teal_600"
        android:layout_marginBottom="16dp" android:clickable="true" android:focusable="true"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🍅 Técnica Pomodoro" android:textSize="22sp"
        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"
        android:layout_marginBottom="4dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Mantén el foco y descansa bien" android:textSize="13sp"
        android:textColor="@color/gray_400" android:layout_marginBottom="24dp"/>

    <!-- Fase actual -->
    <TextView android:id="@+id/tvPhase"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="📚 Tiempo de estudio" android:textSize="16sp"
        android:fontFamily="sans-serif-medium" android:textColor="@color/teal_600"
        android:gravity="center" android:layout_marginBottom="24dp"/>

    <!-- Timer grande -->
    <TextView android:id="@+id/tvTimer"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="25:00" android:textSize="64sp"
        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"
        android:gravity="center" android:layout_marginBottom="12dp"/>

    <!-- Progress bar -->
    <ProgressBar android:id="@+id/progressPomodoro"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent" android:layout_height="8dp"
        android:max="100" android:progress="0"
        android:progressTint="@color/teal_600"
        android:progressBackgroundTint="@color/gray_200"
        android:layout_marginBottom="24dp"/>

    <!-- Controles -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:layout_marginBottom="16dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnReset"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Reiniciar" style="@style/Widget.Equilibrio.Button.Outline"
            android:layout_marginEnd="12dp" android:paddingHorizontal="20dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnStartPause"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Iniciar" style="@style/Widget.Equilibrio.Button"
            android:paddingHorizontal="32dp"/>
    </LinearLayout>

    <!-- Sesiones -->
    <TextView android:id="@+id/tvSessionCount"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Sesiones completadas: 0" android:textSize="13sp"
        android:textColor="@color/gray_400" android:gravity="center" android:layout_marginBottom="24dp"/>

    <!-- Configuración tiempos -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:cardCornerRadius="14dp" app:cardElevation="0dp"
        app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CONFIGURACIÓN" android:textSize="11sp"
                android:fontFamily="sans-serif-medium" android:textColor="@color/gray_400"
                android:letterSpacing="0.08" android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Trabajo"
                    android:textSize="13sp" android:textColor="@color/gray_900"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnWorkMinus"
                    android:layout_width="32dp" android:layout_height="32dp" android:text="−"
                    android:textSize="16sp" style="@style/Widget.Equilibrio.Button.Outline"
                    android:paddingHorizontal="0dp" android:paddingVertical="0dp"/>
                <TextView android:id="@+id/tvWorkMinutes"
                    android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="25min" android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" android:gravity="center" android:textColor="@color/gray_900"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnWorkPlus"
                    android:layout_width="32dp" android:layout_height="32dp" android:text="+"
                    android:textSize="16sp" style="@style/Widget.Equilibrio.Button.Outline"
                    android:paddingHorizontal="0dp" android:paddingVertical="0dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Descanso"
                    android:textSize="13sp" android:textColor="@color/gray_900"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnBreakMinus"
                    android:layout_width="32dp" android:layout_height="32dp" android:text="−"
                    android:textSize="16sp" style="@style/Widget.Equilibrio.Button.Outline"
                    android:paddingHorizontal="0dp" android:paddingVertical="0dp"/>
                <TextView android:id="@+id/tvBreakMinutes"
                    android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="5min" android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" android:gravity="center" android:textColor="@color/gray_900"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnBreakPlus"
                    android:layout_width="32dp" android:layout_height="32dp" android:text="+"
                    android:textSize="16sp" style="@style/Widget.Equilibrio.Button.Outline"
                    android:paddingHorizontal="0dp" android:paddingVertical="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
