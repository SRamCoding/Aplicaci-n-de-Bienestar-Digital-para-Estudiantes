<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Estadísticas" android:textSize="22sp" android:fontFamily="sans-serif-medium"
                android:textColor="@color/gray_900"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Análisis de tu uso digital" android:textSize="13sp" android:textColor="@color/gray_400"/>
        </LinearLayout>

        <!-- Filtros de período -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="16dp" android:paddingBottom="10dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnToday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hoy" style="@style/Widget.Equilibrio.Button.Outline"
                android:layout_marginEnd="6dp" android:paddingHorizontal="16dp" android:paddingVertical="6dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnWeek"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Semana" style="@style/Widget.Equilibrio.Button.Outline"
                android:layout_marginEnd="6dp" android:paddingHorizontal="16dp" android:paddingVertical="6dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnMonth"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mes" style="@style/Widget.Equilibrio.Button.Outline"
                android:paddingHorizontal="16dp" android:paddingVertical="6dp"/>
        </LinearLayout>

        <!-- Métricas rápidas -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="16dp" android:paddingBottom="10dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp"
                app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/tvTotalTime" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="20sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tiempo total" android:textSize="11sp" android:textColor="@color/gray_400"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp"
                app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/tvUnlocks" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--" android:textSize="20sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Desbloqueos" android:textSize="11sp" android:textColor="@color/gray_400"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="14dp" app:cardElevation="0dp"
                app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:id="@+id/tvChange" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--%" android:textSize="20sp"
                        android:fontFamily="sans-serif-medium" android:textColor="@color/red_400"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="vs. ayer" android:textSize="11sp" android:textColor="@color/gray_400"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Gráfico de pastel -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DISTRIBUCIÓN POR CATEGORÍA" android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/gray_400"
                    android:letterSpacing="0.08" android:layout_marginBottom="10dp"/>
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"/>
                <!-- Leyenda manual -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/amber_400" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Redes sociales"
                            android:textSize="12sp" android:textColor="@color/gray_600"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/blue_400" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Entretenimiento"
                            android:textSize="12sp" android:textColor="@color/gray_600"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="10dp" android:layout_height="10dp"
                            android:background="@color/teal_600" android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Mensajería"
                            android:textSize="12sp" android:textColor="@color/gray_600"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gráfico por hora -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HORA DE MAYOR USO" android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/gray_400"
                    android:letterSpacing="0.08" android:layout_marginBottom="10dp"/>
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartHourly"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Racha -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp" app:cardElevation="0dp"
            app:strokeWidth="1dp" app:strokeColor="@color/gray_200" app:cardBackgroundColor="@color/white">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:id="@+id/tvStreak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="40sp" android:fontFamily="sans-serif-medium"
                    android:textColor="@color/teal_600" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="días seguidos" android:textSize="14sp" android:textColor="@color/gray_900"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="¡Sigue así!" android:textSize="12sp" android:textColor="@color/gray_400"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔥" android:textSize="32sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
